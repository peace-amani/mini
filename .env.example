# URL of your deployed bot (e.g. https://wolfy-bot.herokuapp.com)
BOT_API_URL=https://your-bot-url.herokuapp.com

# Must match ADMIN_API_KEY on the bot server
ADMIN_API_KEY=your-admin-api-key-here

# Password to log in to the admin dashboard
ADMIN_PASSWORD=your-admin-dashboard-password

# Port to run this web server on (Heroku sets this automatically)
PORT=3000
